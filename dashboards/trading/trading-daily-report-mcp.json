      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "btc-trading-pg"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  profile AS \"Perfil\",\n  COUNT(CASE WHEN side='sell' THEN 1 END) AS \"Sells Fechados\",\n  COUNT(CASE WHEN side='sell' AND pnl > 0 THEN 1 END) AS \"Wins\",\n  COUNT(CASE WHEN side='sell' AND pnl < 0 THEN 1 END) AS \"Losses\",\n  ROUND(\n    100.0 * COUNT(CASE WHEN side='sell' AND pnl > 0 THEN 1 END)\n    / NULLIF(COUNT(CASE WHEN side='sell' THEN 1 END), 0)::numeric, 1\n  ) AS \"Win Rate\",\n  ROUND(SUM(CASE WHEN side='sell' THEN COALESCE(pnl,0) ELSE 0 END)::numeric, 4) AS \"PnL Total\"\nFROM btc.trades\nWHERE dry_run = false AND symbol = 'BTC-USDT'\nGROUP BY profile\nORDER BY profile",
          "refId": "A"
        }
      ],
      "title": "📊 Performance Histórica por Perfil",
      "type": "table"

          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  to_char(to_timestamp(timestamp) AT TIME ZONE 'America/Sao_Paulo', 'HH24:MI') AS \"Hora\",\n  profile AS \"Perfil\",\n  side AS \"Side\",\n  ROUND(price::numeric, 0) AS \"Preço\",\n  ROUND(size::numeric, 6) AS \"Size BTC\",\n  ROUND(COALESCE(pnl, 0)::numeric, 4) AS \"PnL\"\nFROM btc.trades\nWHERE dry_run = false\n  AND symbol = 'BTC-USDT'\n  AND to_timestamp(timestamp) >= NOW() - INTERVAL '24 hours'\nORDER BY timestamp DESC\nLIMIT 30",

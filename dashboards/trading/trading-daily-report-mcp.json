            "uid": "btc-trading-pg"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  to_timestamp(timestamp) AS time,\n  profile,\n  SUM(COALESCE(pnl, 0)::numeric) OVER (\n    PARTITION BY profile ORDER BY timestamp\n    ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW\n  ) AS \"PnL Acumulado\"\nFROM btc.trades\nWHERE dry_run = false\n  AND symbol = 'BTC-USDT'\n  AND side = 'sell'\nORDER BY timestamp",
          "refId": "A"
        }
      ],
      "title": "📈 PnL Acumulado por Perfil",
      "type": "timeseries"
    },

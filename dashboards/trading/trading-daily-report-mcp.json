      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "btc-trading-pg"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  t.profile AS \"Perfil\",\n  COUNT(*) AS \"Entradas Abertas\",\n  ROUND(SUM(t.size)::numeric, 8) AS \"BTC Total\",\n  ROUND(AVG(t.price)::numeric, 2) AS \"Preço Médio Entrada\",\n  (SELECT ROUND(price::numeric, 2) FROM btc.market_states WHERE symbol='BTC-USDT' ORDER BY timestamp DESC LIMIT 1) AS \"Preço Atual\",\n  ROUND(\n    ((SELECT price FROM btc.market_states WHERE symbol='BTC-USDT' ORDER BY timestamp DESC LIMIT 1)::numeric\n      - AVG(t.price)::numeric) * SUM(t.size)::numeric, 4\n  ) AS \"PnL Não Realizado (USD)\",\n  ROUND(\n    ((SELECT price FROM btc.market_states WHERE symbol='BTC-USDT' ORDER BY timestamp DESC LIMIT 1)::numeric\n      / AVG(t.price)::numeric - 1) * 100, 2\n  ) AS \"PnL %\"\nFROM btc.trades t\nWHERE t.dry_run = false\n  AND t.symbol = 'BTC-USDT'\n  AND t.side = 'buy'\n  AND to_timestamp(t.timestamp) >= NOW() - INTERVAL '30 days'\nGROUP BY t.profile\nORDER BY t.profile",

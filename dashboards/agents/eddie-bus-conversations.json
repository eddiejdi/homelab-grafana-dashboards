          "format": "table",
          "rawSql": "SELECT \n    TO_CHAR(timestamp AT TIME ZONE 'America/Sao_Paulo', 'HH24:MI:SS') as \"Hora\",\n    message_type as \"Tipo\",\n    source as \"Origem\",\n    target as \"Destino\",\n    CASE \n        WHEN LENGTH(content) > 200 THEN SUBSTRING(content, 1, 200) || '...'\n        ELSE content\n    END as \"Conteudo\"\nFROM messages\nWHERE $__timeFilter(timestamp)\nORDER BY timestamp DESC\nLIMIT 100",
